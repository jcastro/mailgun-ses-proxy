# Server
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
API_KEY=change-me-to-a-long-random-value
DASHBOARD_JWT_SECRET=change-me-to-another-long-random-value

# Docker Compose MySQL
MYSQL_DATABASE=mailgun_ses_proxy
MYSQL_USER=mailgun_ses_proxy
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me-root
DATABASE_URL=mysql://mailgun_ses_proxy:change-me@db:3306/mailgun_ses_proxy

# AWS credentials
# Use a dedicated IAM user or role with the runtime policy from docs/iam-policies.md.
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me

# AWS regions
SES_REGION=eu-west-1
SES_TRANSACTIONAL_REGION=eu-west-1
SQS_REGION=eu-west-1

# SES configuration sets
NEWSLETTER_CONFIGURATION_SET_NAME=ghost-newsletter
TRANSACTIONAL_CONFIGURATION_SET_NAME=ghost-transactional

# SQS queue URLs
# NEWSLETTER_QUEUE receives batches from Ghost. NEWSLETTER_NOTIFICATION_QUEUE receives SES events.
NEWSLETTER_QUEUE=https://sqs.eu-west-1.amazonaws.com/123456789012/ghost-ses-newsletter-queue
NEWSLETTER_NOTIFICATION_QUEUE=https://sqs.eu-west-1.amazonaws.com/123456789012/ghost-ses-newsletter-events-queue
TRANSACTIONAL_NOTIFICATION_QUEUE=
NEWSLETTER_VISIBILITY_TIMEOUT=3600
RATE_LIMIT=10
MAX_CONCURRENT=4
SES_BULK_SEND_ENABLED=true
SES_BULK_SEND_SIZE=10
NEWSLETTER_WORKER_BATCH_SIZE=1
SQS_EVENT_RECEIVE_BATCH_SIZE=10
EVENT_MAX_RETRIES=3
EVENT_MISSING_PARENT_RETRY_SECONDS=120
SUPPRESSION_TRANSIENT_BOUNCE_THRESHOLD=3

# Email defaults
SYSTEM_FROM_ADDRESS="Example <noreply@example.com>"

# Optional storage/debug behavior
PERSIST_NEWSLETTER_FORMATTED_CONTENTS=false

# Docker Compose host binding
HOST_BIND=127.0.0.1
HOST_PORT=3000
IMAGE=ghcr.io/jcastro/mailgun-ses-proxy:latest
